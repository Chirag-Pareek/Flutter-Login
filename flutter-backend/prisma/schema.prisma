// Prisma client generation target used by the NestJS app.
generator client {
  provider = "prisma-client-js"
}

// PostgreSQL datasource configured via environment variable.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core application user entity for authentication and authorization.
model User {
  id           Int     @id @default(autoincrement())
  name         String
  email        String  @unique
  password     String
  refreshToken String?
  role         String  @default("user")
}
